# Copy to .env and fill in your values. .env is gitignored.

# Anthropic API key — unlocks API mode for the light pass (faster, prompt-cached).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional: override the model used by batch-light-api.mjs (default: claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001
